{"version":3,"kind":"Article","sha256":"a1bcb111dbae873f23b9db4954e1c214ade329787dc4c03c9d9327adff9a22c6","slug":"related-standards","location":"/reference/related-standards.md","dependencies":[],"frontmatter":{"title":"Related Standards and Specifications","content_includes_title":false,"github":"https://github.com/open223/docs.open223.info","numbering":{"title":{"offset":1}},"source_url":"https://github.com/open223/docs.open223.info/blob/main/reference/related-standards.md","edit_url":"https://github.com/open223/docs.open223.info/edit/main/reference/related-standards.md","exports":[{"format":"md","filename":"related-standards.md","url":"/build/related-standards-bf7a48cee8c5c3f1608c3e13f9d0f626.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"ASHRAE Standard 223P defines a semantic data model for building automation and control data. It does not address every aspect of the broader building data ecosystem. This page identifies related standards and specifications that practitioners may want to consult alongside 223P, organized by topic area. This is not an exhaustive list, but rather a starting point for practitioners to explore the broader landscape of building data standards.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"phbvhTHC9I"}],"key":"y1fxdHmtPm"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Note","key":"rwLLybJISv"}],"key":"h4aqZiHQyf"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"If you have suggestions for additional standards or specifications to include here, please submit an issue or pull request on the 223P GitHub repository.\nWe also welcome concrete examples of how practitioners have used these standards in conjunction with 223P and additional guidance on how to implement them together in practice.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"k2MjienpSJ"}],"key":"Xn3sDuWAZD"}],"key":"ZurK2xNwbB"},{"type":"heading","depth":2,"position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"Building Information Modelling (BIM)","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"f2vGODnijn"}],"identifier":"building-information-modelling-bim","label":"Building Information Modelling (BIM)","html_id":"building-information-modelling-bim","implicit":true,"key":"xyqLydweiP"},{"type":"heading","depth":3,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"ISO 19650: Information Management Using BIM","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"h67oRP3ES6"}],"identifier":"iso-19650-information-management-using-bim","label":"ISO 19650: Information Management Using BIM","html_id":"iso-19650-information-management-using-bim","implicit":true,"key":"empZszyiMM"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"link","url":"https://www.iso.org/standard/68078.html","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"ISO 19650","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"uQvT7ek3gc"}],"urlSource":"https://www.iso.org/standard/68078.html","key":"ixkb6W8wxu"},{"type":"text","value":" is the international standard for organizing and digitizing information about buildings and civil engineering works using Building Information Modelling (BIM).\nIt governs the structured process by which building information is created, managed, and delivered across the project lifecycle, including the commissioning and handover milestone.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"sHEvi3dSru"}],"key":"wWDHgkbQ5i"},{"type":"paragraph","position":{"start":{"line":18,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"A 223P semantic model is most naturally initialized at the point when a building transitions from construction to operations.\nISO 19650 governs the information delivery milestones and the Common Data Environment (CDE) that produce BIM deliverables (including equipment schedules, spatial data, and system definitions) which are the natural source material for populating a 223P model.\nPractitioners looking to establish a repeatable process for model initialization should consult ISO 19650 for guidance on information delivery at handover.","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"fXpXflsSf6"}],"key":"SgMRaYdf0q"},{"type":"heading","depth":3,"position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"ISO 16739: Industry Foundation Classes (IFC)","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"T2c6dISMiz"}],"identifier":"iso-16739-industry-foundation-classes-ifc","label":"ISO 16739: Industry Foundation Classes (IFC)","html_id":"iso-16739-industry-foundation-classes-ifc","implicit":true,"key":"gXrnYXy08P"},{"type":"paragraph","position":{"start":{"line":24,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"link","url":"https://www.buildingsmart.org/standards/bsi-standards/industry-foundation-classes/","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"text","value":"IFC (Industry Foundation Classes)","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"LkJT9dwuG3"}],"urlSource":"https://www.buildingsmart.org/standards/bsi-standards/industry-foundation-classes/","key":"hfA8PEsmDf"},{"type":"text","value":" is published as ","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"MbA9qR6Acx"},{"type":"link","url":"https://www.iso.org/standard/84123.html","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"text","value":"ISO 16739-1:2024","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"DEfzNy7EJk"}],"urlSource":"https://www.iso.org/standard/84123.html","key":"PabPtLxj2u"},{"type":"text","value":" and is the international open standard for building data exchange.\nIFC models contain spatial geometry, product properties, and system definitions.","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"sNbI9wmMzh"}],"key":"GxZMTCvSUL"},{"type":"paragraph","position":{"start":{"line":27,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"IFC and 223P address complementary concerns.\nIFC covers the geometry and product layer (spaces, systems, and equipment as physical objects with geometric representations).\n223P covers the operational semantics layer (how data flows, what properties are observed, and how systems are connected for analytics and automation).\nOrganizations building digital twins will frequently work with both, and will need to develop their own mappings between IFC constructs (such as ","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"BQS4dskkl0"},{"type":"inlineCode","value":"IfcSpace","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"WdeCeAkQ9o"},{"type":"text","value":", ","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"utVsm3jiLI"},{"type":"inlineCode","value":"IfcZone","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"ME1nR2rR17"},{"type":"text","value":", and ","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"nxLUiXxi8t"},{"type":"inlineCode","value":"IfcSystem","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"DfVLrXz2XX"},{"type":"text","value":") and the corresponding 223P classes.\nNo standard guidance currently exists for this mapping; practitioners should consult the IFC specification directly.","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"MxBjPkrmUP"}],"key":"suNtrrpuQg"},{"type":"heading","depth":2,"position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"Facility Management","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"fFFLdJgNiu"}],"identifier":"facility-management","label":"Facility Management","html_id":"facility-management","implicit":true,"key":"R9yhAy5FO7"},{"type":"heading","depth":3,"position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"ISO 41001: Facility Management Systems","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"ukFZRnI0Ps"}],"identifier":"iso-41001-facility-management-systems","label":"ISO 41001: Facility Management Systems","html_id":"iso-41001-facility-management-systems","implicit":true,"key":"Viw6xBznlX"},{"type":"paragraph","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"link","url":"https://www.iso.org/standard/68242.html","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"ISO 41001:2018","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"yVL1kCRFbm"}],"urlSource":"https://www.iso.org/standard/68242.html","key":"Wj1Uyu9dKw"},{"type":"text","value":" specifies the requirements for a facility management (FM) system, with guidance for its use, for an organization that wants to demonstrate effective and efficient delivery of FM that supports the objectives of the demand organization.","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"NWvklNCnf7"}],"key":"qV6ul6kKlM"},{"type":"paragraph","position":{"start":{"line":39,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"text","value":"We imagine that facility management organizations will be the users of 223P-enabled building models, and that 223P-derived data will be a key input to FM service delivery and performance management.\nISO 41001 addresses the management system requirements, including information and data management responsibilities, that govern how FM organizations operate.\nPractitioners implementing building intelligence programs alongside an existing FM management system framework may find it useful to understand where 223P-derived data fits within the information management obligations ISO 41001 describes.","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"Vr7muKZoVS"}],"key":"qS0lr3L7U4"},{"type":"heading","depth":3,"position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"children":[{"type":"text","value":"OSCRE Industry Data Model","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"ulKVcHCEoC"}],"identifier":"oscre-industry-data-model","label":"OSCRE Industry Data Model","html_id":"oscre-industry-data-model","implicit":true,"key":"RH9bUPZzGB"},{"type":"paragraph","position":{"start":{"line":45,"column":1},"end":{"line":46,"column":1}},"children":[{"type":"text","value":"The ","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"W9U1p0O4Ym"},{"type":"link","url":"https://oscre.org/","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"children":[{"type":"text","value":"OSCRE Industry Data Model","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"ofhsIC5KrS"}],"urlSource":"https://oscre.org/","key":"BPawKITxOM"},{"type":"text","value":" defines data exchange standards for real estate and facilities management business transactions, including lease data, maintenance transaction data, and FM service data.\nOSCRE (Open Standards Consortium for Real Estate) operates as an industry consortium rather than a formal standards development organization.","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"OZ08zrtfUD"}],"key":"XPwLa8w4rT"},{"type":"paragraph","position":{"start":{"line":48,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"223P addresses the building systems layer; OSCRE addresses the business and operational management layer above it (the organizational and financial context within which building systems operate).\nOrganizations implementing portfolio-scale building intelligence systems that need to connect building system data to real estate business intelligence, lease management, or FM service transactions should consult OSCRE to understand the data exchange standards that govern that layer.","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"Ug5Ut4E4rM"}],"key":"uR59nLjVC7"},{"type":"heading","depth":2,"position":{"start":{"line":51,"column":1},"end":{"line":51,"column":1}},"children":[{"type":"text","value":"Data Quality","position":{"start":{"line":51,"column":1},"end":{"line":51,"column":1}},"key":"M4rwpoC67M"}],"identifier":"data-quality","label":"Data Quality","html_id":"data-quality","implicit":true,"key":"W2djfwiaYv"},{"type":"heading","depth":3,"position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"children":[{"type":"text","value":"ISO 8000: Data Quality","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"key":"mTLzBneL0J"}],"identifier":"iso-8000-data-quality","label":"ISO 8000: Data Quality","html_id":"iso-8000-data-quality","implicit":true,"key":"qrJYKb7Fte"},{"type":"paragraph","position":{"start":{"line":55,"column":1},"end":{"line":56,"column":1}},"children":[{"type":"link","url":"https://www.iso.org/standard/56025.html","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"children":[{"type":"text","value":"ISO 8000","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"key":"fst3PUk2D1"}],"urlSource":"https://www.iso.org/standard/56025.html","key":"h1WvRldMmc"},{"type":"text","value":" is the international standard for data quality.\nIt defines a framework for data quality dimensions including accuracy, completeness, consistency, and timeliness.","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"key":"AVyDBMcT8a"}],"key":"QCukblaFzC"},{"type":"paragraph","position":{"start":{"line":58,"column":1},"end":{"line":60,"column":1}},"children":[{"type":"text","value":"SHACL conformance validation in 223P assesses structural validity (whether a model is correctly formed according to the ontology) and semantic validity (whether the data values conform to the expected types and constraints).\nA validating 223P model may still contain inaccurate sensor readings, an incomplete equipment inventory, or stale data that no longer reflects installed conditions.\nISO 8000 provides a framework for reasoning about these data quality dimensions independently of any specific standard, and practitioners can consult it when assessing whether a model is fit for its intended analytics purpose.","position":{"start":{"line":58,"column":1},"end":{"line":58,"column":1}},"key":"N1tvGOLoEy"}],"key":"USo8fGrQ2M"},{"type":"heading","depth":2,"position":{"start":{"line":62,"column":1},"end":{"line":62,"column":1}},"children":[{"type":"text","value":"Semantic Web Standards","position":{"start":{"line":62,"column":1},"end":{"line":62,"column":1}},"key":"KOlhSXRX2Z"}],"identifier":"semantic-web-standards","label":"Semantic Web Standards","html_id":"semantic-web-standards","implicit":true,"key":"Oz5GJU4B96"},{"type":"heading","depth":3,"position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"children":[{"type":"text","value":"W3C PROV-O: Provenance Ontology","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"kdPyNhWovV"}],"identifier":"w3c-prov-o-provenance-ontology","label":"W3C PROV-O: Provenance Ontology","html_id":"w3c-prov-o-provenance-ontology","implicit":true,"key":"h664wSi8bP"},{"type":"paragraph","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"children":[{"type":"link","url":"https://www.w3.org/TR/prov-o/","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"children":[{"type":"text","value":"W3C PROV-O","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"jYklW9vyFR"}],"urlSource":"https://www.w3.org/TR/prov-o/","key":"ETz0kr8AQX"},{"type":"text","value":" is a W3C standard that provides a set of classes, properties, and restrictions to represent provenance information about the origin, context, and history of data.","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"NVWNuAVULt"}],"key":"QV7f3fCjzm"},{"type":"paragraph","position":{"start":{"line":68,"column":1},"end":{"line":71,"column":1}},"children":[{"type":"text","value":"A 223P building model describes building systems at a point in time.\nAs buildings are modified, recommissioned, or retrofitted, the semantic model must be updated.\nPROV-O is built on RDF (the same foundation as 223P), making it technically compatible for use alongside a 223P model to record provenance information: when the model was created or revised, what data sources were used (commissioning report, BIM model, field survey), and who performed the update.\nPractitioners who need audit trails or who are managing model versions across a portfolio should consult PROV-O as a provenance framework.","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"key":"Wqwo9rQWn2"}],"key":"fJzqlykYG8"},{"type":"heading","depth":2,"position":{"start":{"line":73,"column":1},"end":{"line":73,"column":1}},"children":[{"type":"text","value":"Other Building Ontologies","position":{"start":{"line":73,"column":1},"end":{"line":73,"column":1}},"key":"uilX0fkL6z"}],"identifier":"other-building-ontologies","label":"Other Building Ontologies","html_id":"other-building-ontologies","implicit":true,"key":"U6tcouDOLm"},{"type":"paragraph","position":{"start":{"line":75,"column":1},"end":{"line":75,"column":1}},"children":[{"type":"text","value":"Several community-developed ontologies can be used alongside 223P to enrich building models with additional concepts and vocabularies.","position":{"start":{"line":75,"column":1},"end":{"line":75,"column":1}},"key":"bUos5YT2Si"}],"key":"Kmj6n9euCu"},{"type":"heading","depth":3,"position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"children":[{"type":"text","value":"Brick Schema","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"QxPK3bnHMb"}],"identifier":"brick-schema","label":"Brick Schema","html_id":"brick-schema","implicit":true,"key":"S9xEvm5ax9"},{"type":"paragraph","position":{"start":{"line":79,"column":1},"end":{"line":80,"column":1}},"children":[{"type":"link","url":"https://brickschema.org","position":{"start":{"line":79,"column":1},"end":{"line":79,"column":1}},"children":[{"type":"text","value":"Brick","position":{"start":{"line":79,"column":1},"end":{"line":79,"column":1}},"key":"suzXmP6E8R"}],"urlSource":"https://brickschema.org","key":"Lm3ItIaFGo"},{"type":"text","value":" is an open-source ontology for describing the equipment, points, locations, and metadata found in buildings.\nBrick provides a large vocabulary of building management system (BMS) concepts that complement 223P.","position":{"start":{"line":79,"column":1},"end":{"line":79,"column":1}},"key":"b9TwIifFcb"}],"key":"NZpd9mfNIQ"},{"type":"heading","depth":3,"position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"text","value":"RealEstateCore","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"key":"MrXguV5Dka"}],"identifier":"realestatecore","label":"RealEstateCore","html_id":"realestatecore","implicit":true,"key":"omVc4cL01j"},{"type":"paragraph","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"children":[{"type":"link","url":"https://realestatecore.io","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"children":[{"type":"text","value":"RealEstateCore","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"key":"LCN7DQ8ImH"}],"urlSource":"https://realestatecore.io","key":"Dmi7SAq6Nm"},{"type":"text","value":" is an ontology for describing real estate assets including buildings, rooms, and building systems, with a focus on the needs of real estate owners and operators.","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"key":"nCP5vMlZCD"}],"key":"ps6TWS9BbU"},{"type":"paragraph","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"children":[{"type":"text","value":"See ","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"key":"XocvHOuxvp"},{"type":"link","url":"/brick-rec","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"children":[{"type":"text","value":"Using 223 with Brick and RealEstateCore","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"key":"GiBMnavnBC"}],"urlSource":"../guides/brick-rec.md","dataUrl":"/brick-rec.json","internal":true,"protocol":"file","key":"QcAogtENM2"},{"type":"text","value":" for guidance on combining these ontologies with 223P models.","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"key":"dfnkCWRETu"}],"key":"T2OTVHpsWG"}],"key":"Bc7x4VesvH"}],"key":"v1xF1k0lkG"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Other Resources","url":"/other-resources","group":"Reference"}}},"domain":"http://localhost:3000"}